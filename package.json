{
  "name": "bulir-challenges",
  "version": "0.0.1",
  "description": "Monorepo for bulir challenges with NestJS backend, Next.js web, and Expo mobile apps",
  "license": "UNLICENSED",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "build": "nx run-many --target=build --all",
    "dev": "nx run-many --target=serve --all --parallel",
    "dev:web": "nx run web:dev",
    "dev:backend": "nx run backend:serve",
    "clean": "rm -rf dist node_modules",
    "prisma:generate": "prisma generate --schema apps/backend/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema apps/backend/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema apps/backend/prisma/schema.prisma",
    "build:backend": "nx build backend --configuration=production"
  },
  "prisma": {
    "schema": "apps/backend/prisma/schema.prisma"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/eslint": "22.6.4",
    "@nx/eslint-plugin": "22.6.4",
    "@nx/expo": "^22.6.4",
    "@nx/jest": "22.6.4",
    "@nx/js": "22.6.4",
    "@nx/nest": "^22.6.4",
    "@nx/next": "^22.6.4",
    "@nx/node": "22.6.4",
    "@nx/react": "^22.6.4",
    "@nx/web": "22.6.4",
    "@nx/webpack": "22.6.4",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "10.4.13",
    "babel-jest": "^30.0.2",
    "eslint": "^9.8.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "nx": "^22.6.4",
    "postcss": "8.4.38",
    "prettier": "~3.6.2",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tailwindcss": "3.4.3",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tamagui/core": "^2.0.0-rc.37",
    "axios": "^1.6.0",
    "client-only": "^0.0.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "~16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "server-only": "^0.0.1",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.3.0",
    "zod": "^4.3.6"
  }
}
