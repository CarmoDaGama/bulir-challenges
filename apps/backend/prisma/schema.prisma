generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CLIENT
  PROVIDER
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  nif          String        @unique
  name         String
  passwordHash String
  role         UserRole
  balance      Decimal       @default(0) @db.Decimal(12, 2)
  services     Service[]
  sentTx       Transaction[] @relation("TransactionClient")
  recvTx       Transaction[] @relation("TransactionProvider")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([email])
  @@index([nif])
}

model Service {
  id          String        @id @default(cuid())
  title       String
  description String
  price       Decimal       @db.Decimal(12, 2)
  ownerId     String
  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tx          Transaction[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([ownerId])
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(12, 2)
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  clientId    String
  client      User     @relation("TransactionClient", fields: [clientId], references: [id], onDelete: Restrict)
  providerId  String
  provider    User     @relation("TransactionProvider", fields: [providerId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@index([clientId, createdAt])
  @@index([providerId, createdAt])
  @@index([serviceId])
}
